# Production build flags (Vite loads .env.production during `vite build`).
# Non-secret only — secrets (Stripe keys, Resend) stay as Pages dashboard secrets.

# Use the live booking API for availability so the calendar shows ONLY real
# bookable slots: past hours, already-booked hours, capacity-full days, and
# blocked dates are filtered server-side. Off => static mock slots (dev only).
VITE_USE_BOOKING_API=true
