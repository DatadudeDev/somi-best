# ─────────────────────────────────────────────────────────────────────────────
# Frontend build vars (VITE_*) — loaded by Vite at build/dev time.
# Copy this file to `.env` for local development.
# ─────────────────────────────────────────────────────────────────────────────

# Stripe publishable key (safe to expose in the browser bundle)
# Get from: https://dashboard.stripe.com/apikeys
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Switch the booking form off mock availability and onto the live /api/* backend.
# Set to true once the Pages Functions + D1 below are deployed.
VITE_USE_BOOKING_API=true

# Optional: require service address on checkout (mirror BOOKING_REQUIRES_ADDRESS on server)
# VITE_BOOKING_REQUIRES_ADDRESS=false

# Optional: Google Places autocomplete on /book
# VITE_GOOGLE_MAPS_API_KEY=

# Optional: Cloudflare Turnstile widget
# VITE_TURNSTILE_SITE_KEY=

# Optional: fetch live Google rating/reviews on homepage (default off — uses static fallbacks)
# VITE_ENABLE_GOOGLE_REVIEWS_API=true

# Optional: regenerate social preview image (npm run generate:og-image)
# OG_TAGLINE= OG_SUBTITLE= OG_SITE_HOST=treytherapy.com

# Optional: client analytics endpoint (enables tracker observers in production)
# VITE_ANALYTICS_ENDPOINT=

# Public site origin (canonical URLs, index.html OG tags, JSON-LD)
VITE_SITE_ORIGIN=https://treytherapy.com

# Legal pages (Privacy / Terms) — baked in at build time
VITE_BUSINESS_NAME=BEST Therapy
VITE_BUSINESS_LEGAL_NAME=BEST Therapeutics LLC
VITE_BUSINESS_LOCATION=Calgary, AB, Canada
# VITE_BUSINESS_CITY=Calgary
# VITE_BUSINESS_REGION=AB
# VITE_LEGAL_EFFECTIVE_DATE=June 1, 2026

# ─────────────────────────────────────────────────────────────────────────────
# Backend (Pages Functions) config — NOT loaded by Vite.
# For local `wrangler pages dev`, put these in `.dev.vars`.
# For production, set as Pages environment variables / secrets in the dashboard.
# ─────────────────────────────────────────────────────────────────────────────

# Vars (per-client; have safe defaults baked into wrangler.toml)
# CURRENCY=usd
# TIMEZONE=America/Edmonton
# BUSINESS_NAME=Your Business Name
# BOOKING_REQUIRES_ADDRESS=false
# SITE_ORIGIN=https://your-domain.com
# EMAIL_LOGO_URL=https://your-domain.com/images/logo-mark.png
# EMAIL_LOCATION_LABEL=Your City, ST
# BUSINESS_NOTIFY_EMAIL=bookings@client.com
# REPLY_TO_EMAIL=hello@client.com
# FROM_EMAIL=bookings@send.somi.ceo

# Secrets (set via `wrangler pages secret put <NAME>` in production)
# STRIPE_SECRET_KEY=sk_test_XXXXXXXXXXXXXXXXXXXXXXXXXXXX
# STRIPE_WEBHOOK_SIGNING_SECRET=whsec_XXXXXXXXXXXXXXXXXXXX
# RESEND_API_KEY=re_XXXXXXXXXXXXXXXXXXXXXXXX  # required for /api/contact + booking emails
# TURNSTILE_SECRET_KEY=  # optional — enables booking bot verification

