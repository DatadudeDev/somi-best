# ─────────────────────────────────────────────────────────────────────────────
# Frontend build vars (VITE_*) — loaded by Vite at build/dev time.
# Copy this file to `.env` for local development.
# ─────────────────────────────────────────────────────────────────────────────

# Stripe publishable key (safe to expose in the browser bundle)
# Get from: https://dashboard.stripe.com/apikeys
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Switch the booking form off mock availability and onto the live /api/* backend.
# Set to true once the Pages Functions + D1 below are deployed.
VITE_USE_BOOKING_API=true

# Optional: Google Places autocomplete on /book
# VITE_GOOGLE_MAPS_API_KEY=

# Optional: Cloudflare Turnstile widget
# VITE_TURNSTILE_SITE_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# Backend (Pages Functions) config — NOT loaded by Vite.
# For local `wrangler pages dev`, put these in `.dev.vars`.
# For production, set as Pages environment variables / secrets in the dashboard.
# ─────────────────────────────────────────────────────────────────────────────

# Vars (per-client; have safe defaults baked into wrangler.toml)
# CURRENCY=usd
# TIMEZONE=America/Denver
# BUSINESS_NAME=Acme Home Services
# BUSINESS_NOTIFY_EMAIL=bookings@client.com
# REPLY_TO_EMAIL=hello@client.com
# FROM_EMAIL=bookings@send.somi.ceo

# Secrets (set via `wrangler pages secret put <NAME>` in production)
# STRIPE_SECRET_KEY=sk_test_XXXXXXXXXXXXXXXXXXXXXXXXXXXX
# STRIPE_WEBHOOK_SIGNING_SECRET=whsec_XXXXXXXXXXXXXXXXXXXX
# RESEND_API_KEY=re_XXXXXXXXXXXXXXXXXXXXXXXX
# TURNSTILE_SECRET_KEY=  # optional — enables booking bot verification

